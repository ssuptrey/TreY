# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
# Option 1: Cloud Database (Recommended - Neon/Supabase/Railway)
DATABASE_URL=postgresql://username:password@your-host.region.provider.tech/database?sslmode=require

# Option 2: Local Database (Legacy - only if you have PostgreSQL installed locally)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=compliance_execution
# DB_USER=postgres
# DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads

# Email Configuration (for SLA Alerts)
# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@compliance-system.com

# For Gmail, enable "Less secure app access" or use App Password
# https://support.google.com/accounts/answer/185833

# Timezone (for cron jobs)
TZ=Asia/Kolkata

# Development Options
RUN_ALERTS_ON_STARTUP=false
